# App server
HOST=0.0.0.0
PORT=8000
WEB_CONCURRENCY=1
UVICORN_RELOAD=false

# CORS
# Use * for quick testing, or a comma-separated list like:
# CORS_ORIGINS=https://your-domain.com,http://<vm-public-ip>
CORS_ORIGINS=*

# Paths
DATASET_PATH=btc_usd_2y_1h_data.csv
MODEL_PATH=models/linear_regression_model.joblib
FRONTEND_DIR=frontend
MLFLOW_DB_PATH=mlflow.db

# MLflow
MLFLOW_EXPERIMENT_NAME=btc_forecasting_pipeline
# Leave blank to use the local SQLite database above.
# Example remote value:
# MLFLOW_TRACKING_URI=http://127.0.0.1:5000
MLFLOW_TRACKING_URI=
